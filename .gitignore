# Local environment variables (contains database passwords!)
.env

# Ignore all raw data files and folders
data/raw/
data/processed/
*.csv
*.xlsx

# ...except dbt seeds, which are source-controlled lookup tables, not data dumps
!dbt/**/seeds/**/*.csv

# Python system/cache files
__pycache__/
*.pyc
.venv/
.vscode/
.ipynb_checkpoints/

# dbt generated artifacts (any dbt project, any depth)
target/
logs/
dbt_packages/